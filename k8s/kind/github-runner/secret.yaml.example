# 不要提交真实 token！这是模板文件。
# 实际创建方式：
# kubectl create secret generic github-token \
#   --namespace github-runner \
#   --from-literal=github_token=<YOUR_GITHUB_PAT>
#
# GitHub PAT 需要以下权限：
#   - repo (Full control)
#   - workflow
#   - admin:org → read:org (org runner 需要)

apiVersion: v1
kind: Secret
metadata:
  name: github-token
  namespace: github-runner
type: Opaque
stringData:
  github_token: <YOUR_GITHUB_PAT>
