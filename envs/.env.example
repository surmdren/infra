# DreamAI 基础设施连接信息模板
# 复制为 dev.env 或 prod.env 并填入真实值
# 这些变量供各 SaaS 项目引用，不要直接提交含真实值的文件

# ─── K8s 集群 ──────────────────────────────────────────
# kubeconfig context 名称（dev / prod）
K8S_CONTEXT=dev

# ─── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://supabase-dev.dreamwiseai.com
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Chatwoot ──────────────────────────────────────────
CHATWOOT_URL=https://chatwoot-dev.dreamwiseai.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_TOKEN=                    # SuperAdmin API Token，从 Profile Settings 获取

# ─── 数据库直连（内部服务用）─────────────────────────
# Supabase PostgreSQL
DB_HOST=supabase-dev.dreamwiseai.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
