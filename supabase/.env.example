############
# 必填配置 - 部署前必须修改
############

# JWT 密钥（至少32位随机字符串）
JWT_SECRET=your-super-secret-jwt-token-change-this
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# 数据库密码
POSTGRES_PASSWORD=your-database-password

# Dashboard 登录密码
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-dashboard-password

############
# 邮件服务（用于注册验证/密码重置）
############
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=DreamAI Platform

############
# 站点配置
############
SITE_URL=http://localhost:3000
# 生产环境改为你的实际域名，例如：
# SITE_URL=https://platform.dreamai.com

API_EXTERNAL_URL=http://localhost:8000
# 生产环境：
# API_EXTERNAL_URL=https://api.dreamai.com

############
# 存储配置
############
# 本地存储路径（Docker volume）
STORAGE_BACKEND=file

# 可选：换成 S3 兼容存储（阿里云 OSS、MinIO 等）
# STORAGE_BACKEND=s3
# GLOBAL_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_DEFAULT_REGION=cn-hangzhou
# AWS_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com

############
# 微信登录（可选）
############
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
